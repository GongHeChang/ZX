        """

自定义通信协议编解码
模拟ESP32和APP之间的二进制通信协议
在demo中使用JSON简化，但保留协议结构
"""
import json
import hashlib
from datetime import datetime

class ProtocolCodec:
    # 帧类型
    FRAME_SENSOR_DATA = 0x01
    FRAME_EVENT = 0x02
    FRAME_HEARTBEAT = 0xFF
    FRAME_ACHIEVEMENT = 0x20
    

    def encode(self, processed_packet):
        """将处理后的数据编码为传输格式"""
        frame = {
            "head": "AA55",
            "type": self.FRAME_SENSOR_DATA,
            "payload": processed_packet,
            "crc": self._calc_crc(json.dumps(processed_packet)),
            "tail": "FE",
            "encoded_at": datetime.now().isoformat()
        }
        return json.dumps(frame)
    
    def encode_heartbeat(self, system_state):
        """编码心跳包"""
        frame = {
            "head": "AA55",
            "type": self.FRAME_HEARTBEAT,
            "payload": {
                "sensor_connected": system_state.get("sensor_connected", False),
                "active_sensors": system_state.get("active_sensors", []),
                "total_processed": system_state.get("total_processed", 0),
                "events_detected": system_state.get("events_detected", 0),
                "offline_mode": system_state.get("offline_mode", False),
            },
            "crc": "heartbeat",
            "tail": "FE",
            "encoded_at": datetime.now().isoformat()
        }
        return json.dumps(frame)
    
    def decode(self, raw_message):
        """解码接收到的消息"""
        try:
            frame = json.loads(raw_message)
            if frame.get("head") != "AA55" or frame.get("tail") != "FE":
                return None
            return {
                "type": frame.get("type"),
                "payload": frame.get("payload"),
                "valid": True
            }
        except json.JSONDecodeError:
            return None
    
    def _calc_crc(self, data_str):
        """简化的CRC计算"""
        return hashlib.md5(data_str.encode()).hexdigest()[:8]






















