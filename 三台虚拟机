负责与COZE云端AI进行通信
"""
import requests
import json
import time

class CozeClient:
    def __init__(self, bot_id, api_token, api_base="https://api.coze.cn"):
        self.bot_id = bot_id
        self.api_token = api_token
        self.api_base = api_base
        self.conversation_id = None
        self.user_id = "child_explorer_001"
        

    def chat(self, message, sensor_context=None, game_state=None):
        """
        发送消息给COZE智能体并获取回复
        
        参数:
            message: 用户消息或系统事件描述
            sensor_context: 传感器上下文信息
            game_state: 当前游戏状态
        """
        url = f"{self.api_base}/v3/chat"
        
        headers = {
            "Authorization": f"Bearer {self.api_token}",
            "Content-Type": "application/json"
        }
        
        # 构建带传感器上下文的消息
        enhanced_message = message
        if sensor_context:
            enhanced_message += f"\n\n[传感器上下文]\n{json.dumps(sensor_context, ensure_ascii=False)}"
        if game_state:
            enhanced_message += f"\n\n[游戏状态]\n{json.dumps(game_state, ensure_ascii=False)}"
        
        body = {
            "bot_id": self.bot_id,
            "user_id": self.user_id,
            "stream": False,
            "auto_save_history": True,
            "additional_messages": [
                {
                    "role": "user",
                    "content": enhanced_message,
                    "content_type": "text"
                }
            ]
        }
        
        if self.conversation_id:
            body["conversation_id"] = self.conversation_id
        
        try:
            response = requests.post(url, headers=headers, json=body, timeout=30)
            
            if response.status_code == 200:
                data = response.json()
                
                # 保存conversation_id用于多轮对话
                if data.get("data", {}).get("conversation_id"):
                    self.conversation_id = data["data"]["conversation_id"]
                
                # 轮询获取结果
                chat_id = data.get("data", {}).get("id")
                if chat_id:
                    return self._poll_result(chat_id)
                    
                return {
                    "success": True,
                    "reply": data.get("data", {}).get("content", "小光正在思考中..."),
                    "raw": data
                }
            else:
                return {
                    "success": False,
                    "reply": f"AI暂时无法回应 (HTTP {response.status_code})",
                    "error": response.text
                }
                
        except requests.exceptions.Timeout:
            return {"success": False, "reply": "小光思考太久了，请再试一次~"}
        except requests.exceptions.ConnectionError:
            return {"success": False, "reply": "无法连接到AI服务器，请检查网络"}
        except Exception as e:
            return {"success": False, "reply": f"出了点小问题: {str(e)}"}
    
    def _poll_result(self, chat_id):
        """轮询获取聊天结果"""
        url = f"{self.api_base}/v3/chat/retrieve"
        headers = {
            "Authorization": f"Bearer {self.api_token}",
            "Content-Type": "application/json"
        }
        
        for _ in range(30):  # 最多等30秒
            try:
                response = requests.post(url, headers=headers, json={
                    "chat_id": chat_id,
                    "conversation_id": self.conversation_id
                }, timeout=10)
                
                if response.status_code == 200:
                    data = response.json()
                    status = data.get("data", {}).get("status")
                    
                    if status == "completed":
                        # 获取消息列表
                        return self._get_messages(chat_id)
                    elif status == "failed":
                        return {"success": False, "reply": "小光遇到了困难，请再试一次"}
                
                time.sleep(1)
            except:
                time.sleep(1)
        
        return {"success": False, "reply": "小光思考了很久，请再试一次"}
    
    def _get_messages(self, chat_id):
        """获取聊天消息列表"""
        url = f"{self.api_base}/v3/chat/message/list"
        headers = {
            "Authorization": f"Bearer {self.api_token}",
            "Content-Type": "application/json"
        }
        
        try:
            response = requests.post(url, headers=headers, json={
                "chat_id": chat_id,
                "conversation_id": self.conversation_id
            }, timeout=10)
            
            if response.status_code == 200:
                data = response.json()
                messages = data.get("data", [])
                
                # 找到AI的回复
                for msg in messages:
                    if msg.get("role") == "assistant" and msg.get("type") == "answer":
                        return {
                            "success": True,
                            "reply": msg.get("content", ""),
                        }
            
            return {"success": False, "reply": "小光的回复走丢了..."}
            
        except Exception as e:
            return {"success": False, "reply": f"获取回复失败: {str(e)}"}


