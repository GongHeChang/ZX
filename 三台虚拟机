    """

边缘计算引擎 — 在ESP32本地进行数据处理
模拟滑动窗口、趋势分析、事件检测
"""
import math
import time
from collections import deque

class EdgeComputeEngine:
    def __init__(self, window_size=20):
        self.window_size = window_size
        # 每种传感器维护一个滑动窗口
        self.windows = {}
        

    def process(self, reading):
        """处理单条传感器数据，返回带边缘计算结果的数据"""
        sensor_type = reading.get("sensor_type", 0)
        raw_value = reading.get("raw_value", 0)
        
        # 更新滑动窗口
        if sensor_type not in self.windows:
            self.windows[sensor_type] = deque(maxlen=self.window_size)
        self.windows[sensor_type].append(raw_value)
        
        window = list(self.windows[sensor_type])
        
        # 计算统计特征
        avg = sum(window) / len(window) if window else raw_value
        std_dev = self._std_dev(window) if len(window) > 1 else 0
        trend = self._trend(window) if len(window) > 2 else 0
        
        # 传感器特定的边缘计算
        computed_value = raw_value
        event_type = "none"
        description = ""
        
        if sensor_type == 1:  # 温度
            computed_value = raw_value
            rate = (window[-1] - window[0]) / max(len(window) * 0.5, 0.1) if len(window) > 1 else 0
            if raw_value > 35:
                event_type = "body_heat"
                description = f"检测到体温！约{raw_value:.1f}°C，你的手好温暖~"
            elif raw_value < 5:
                event_type = "freezing"
                description = f"好冷！温度只有{raw_value:.1f}°C，分子们在发抖呢"
            elif abs(rate) > 2:
                event_type = "rapid_temp_change"
                direction = "升高" if rate > 0 else "降低"
                description = f"温度在快速{direction}！变化率约{abs(rate):.1f}°C/s"
                
        elif sensor_type == 2:  # 光线
            computed_value = raw_value
            if raw_value > 10000:
                event_type = "bright_light"
                description = f"好亮！光照强度{raw_value:.0f}Lux，像在阳光下"
            elif raw_value < 10:
                event_type = "darkness"
                description = f"好暗！只有{raw_value:.0f}Lux，光精灵们在休息"
                
        elif sensor_type == 3:  # 声音
            # 转换为分贝
            rms = math.sqrt(sum(v**2 for v in window) / len(window)) if window else raw_value
            db = 20 * math.log10(max(rms, 0.001) / 0.02) if rms > 0 else 0
            computed_value = round(db, 1)
            if db > 80:
                event_type = "loud_sound"
                description = f"好大的声音！约{db:.0f}分贝，声波在空气中震荡"
            elif db < 25:
                event_type = "silence"
                description = f"好安静~只有{db:.0f}分贝"
                
        elif sensor_type == 4:  # 加速度
            computed_value = std_dev  # 标准差反映运动剧烈程度
            if abs(raw_value) < 0.5:
                event_type = "freefall_detected"
                description = f"自由落体！加速度接近0，重力在作用！"
            elif std_dev > 5:
                event_type = "shaking"
                description = f"检测到剧烈摇晃！加速度波动很大"
            elif abs(raw_value - 9.8) < 0.5 and std_dev < 0.3:
                event_type = "still"
                description = "静止状态，重力加速度约9.8m/s²"
                
        elif sensor_type == 5:  # 距离
            computed_value = raw_value
            if raw_value < 10:
                event_type = "very_close"
                description = f"非常近！只有{raw_value:.1f}cm"
            elif raw_value > 300:
                event_type = "far_away"
                description = f"很远！{raw_value:.1f}cm，超声波飞了很久"
                
        elif sensor_type == 6:  # 湿度
            computed_value = raw_value
            if raw_value > 80:
                event_type = "very_humid"
                description = f"空气好潮湿！{raw_value:.0f}%RH，水精灵们在跳舞"
            elif raw_value < 20:
                event_type = "very_dry"
                description = f"空气很干燥，只有{raw_value:.0f}%RH"
                
        elif sensor_type == 7:  # 气压
            # 计算估算海拔
            altitude = 44330 * (1 - (raw_value / 1013.25) ** (1/5.255))
            computed_value = round(altitude, 1)
            if raw_value < 900:
                event_type = "high_altitude"
                description = f"气压较低！估算海拔约{altitude:.0f}米"
            else:
                description = f"气压{raw_value:.1f}hPa，估算海拔{altitude:.0f}米"
                
        elif sensor_type == 8:  # 磁场
            computed_value = abs(raw_value)
            if abs(raw_value) > 60:
                event_type = "strong_magnetic"
                description = f"检测到强磁场！{abs(raw_value):.1f}μT，附近有磁铁"
            elif abs(raw_value) < 10:
                event_type = "weak_magnetic"
                description = f"磁场很弱，只有{abs(raw_value):.1f}μT"
        
        return {
            "sensor_type": sensor_type,
            "sensor_name": reading.get("sensor_name", ""),
            "raw_value": raw_value,
            "calibrated_value": round(raw_value, 3),
            "computed_value": round(computed_value, 3),
            "unit": reading.get("unit", ""),
            "event_type": event_type,
            "description": description,
            "statistics": {
                "average": round(avg, 3),
                "std_dev": round(std_dev, 3),
                "trend": round(trend, 3),
                "window_size": len(window)
            },
            "timestamp": reading.get("timestamp", "")
        }
    
    def _std_dev(self, data):
        avg = sum(data) / len(data)
        variance = sum((x - avg) ** 2 for x in data) / len(data)
        return math.sqrt(variance)
    
    def _trend(self, data):
        """简单线性趋势（正=上升，负=下降）"""
        n = len(data)
        if n < 2:
            return 0
        x_mean = (n - 1) / 2
        y_mean = sum(data) / n
        num = sum((i - x_mean) * (data[i] - y_mean) for i in range(n))
        den = sum((i - x_mean) ** 2 for i in range(n))
        return num / den if den != 0 else 0




























