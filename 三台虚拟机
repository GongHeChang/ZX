    # VM2
    # 创建RTOS主程序
    # 
    #!/usr/bin/env python3

"""
====================================================

VM2 - ESP32 FreeRTOS 模拟器
====================================================

用 Python 线程模拟 FreeRTOS 任务调度

- Task1: 传感器数据接收 (模拟I2C/SPI读取) — 高优先级

- Task2: 边缘计算处理 — 中高优先级

- Task3: 通信管理 (向APP发送数据) — 中优先级

- Task4: 离线游戏逻辑 — 低优先级

- Task5: 传感器热插拔检测 — 低优先级
  ====================================================

  """

import threading
import queue
import socket
import json
import time
import sys
import signal
from datetime import datetime

from edge_compute import EdgeComputeEngine
from protocol import ProtocolCodec
from offline_cache import OfflineCache

# ========== 配置 ==========

SENSOR_LISTEN_PORT = 9001   # 监听传感器数据
APP_SERVE_PORT = 9002       # 向APP提供数据
MAX_QUEUE_SIZE = 64

# ========== 全局队列（模拟FreeRTOS Queue）==========

xSensorDataQueue = queue.Queue(maxsize=MAX_QUEUE_SIZE)
xProcessedDataQueue = queue.Queue(maxsize=MAX_QUEUE_SIZE)
xAppCommandQueue = queue.Queue(maxsize=16)

# ========== 全局状态 ==========

system_state = {
    "sensor_connected": False,
    "app_connected": False,
    "active_sensors": [],
    "total_processed": 0,
    "events_detected": 0,
    "uptime_start": time.time(),
    "offline_mode": False,
}

# 互斥锁（模拟FreeRTOS Mutex）

state_mutex = threading.Lock()

# ========== 边缘计算引擎 ==========

edge_engine = EdgeComputeEngine()
protocol = ProtocolCodec()
offline_cache = OfflineCache()


class RTOSTask:
    """FreeRTOS 任务基类"""
    def __init__(self, name, priority, core, period_ms=None):
        self.name = name
        self.priority = priority
        self.core = core
        self.period_ms = period_ms
        self.running = True
        self.thread = None
        self.cycle_count = 0
    

    def start(self):
        self.thread = threading.Thread(target=self._run_wrapper, daemon=True)
        self.thread.start()
        print(f"  ✅ Task [{self.name}] 已启动 | 优先级:P{self.priority} | 核心:Core{self.core}")
    
    def _run_wrapper(self):
        try:
            self.run()
        except Exception as e:
            print(f"\n❌ Task [{self.name}] 异常: {e}")
    
    def run(self):
        raise NotImplementedError


# ================================================================

# Task 1: 传感器数据接收任务

# 模拟 ESP32 从 I2C/SPI 总线读取传感器数据

# 实际实现：TCP Server 接收来自 VM1 的传感器数据

# ================================================================

class SensorReceiveTask(RTOSTask):
    def __init__(self):
        super().__init__("SensorReceive", priority=5, core=0, period_ms=50)
        self.server_socket = None
        self.client_socket = None
        

    def run(self):
        # 创建TCP服务器，等待传感器连接
        self.server_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.server_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        self.server_socket.bind(('0.0.0.0', SENSOR_LISTEN_PORT))
        self.server_socket.listen(1)
        print(f"\n📡 等待传感器连接 (端口 {SENSOR_LISTEN_PORT})...")
        
        while self.running:
            try:
                self.client_socket, addr = self.server_socket.accept()
                print(f"\n✅ 传感器已连接: {addr}")
                with state_mutex:
                    system_state["sensor_connected"] = True
                
                self._receive_loop()
                
            except Exception as e:
                print(f"\n⚠️ 传感器连接异常: {e}")
                with state_mutex:
                    system_state["sensor_connected"] = False
                time.sleep(1)
    
    def _receive_loop(self):
        buffer = ""
        while self.running:
            try:
                data = self.client_socket.recv(4096).decode('utf-8')
                if not data:
                    print("\n⚠️ 传感器断开连接")
                    with state_mutex:
                        system_state["sensor_connected"] = False
                    break
                
                buffer += data
                while "\n" in buffer:
                    line, buffer = buffer.split("\n", 1)
                    try:
                        packet = json.loads(line)
                        # 将传感器数据推入队列
                        if not xSensorDataQueue.full():
                            xSensorDataQueue.put(packet, block=False)
                            self.cycle_count += 1
                            
                            # 更新激活传感器列表
                            with state_mutex:
                                system_state["active_sensors"] = packet.get("active_sensors", [])
                    except json.JSONDecodeError:
                        pass
                        
            except (ConnectionResetError, BrokenPipeError):
                print("\n⚠️ 传感器连接断开")
                with state_mutex:
                    system_state["sensor_connected"] = False
                break


# ================================================================

# Task 2: 边缘计算任务

# 从传感器队列取数据，进行本地计算和事件检测

# ================================================================

class EdgeComputeTask(RTOSTask):
    def __init__(self):
        super().__init__("EdgeCompute", priority=4, core=1)
    

    def run(self):
        while self.running:
            try:
                # 从队列获取传感器数据（阻塞等待，模拟 xQueueReceive）
                raw_packet = xSensorDataQueue.get(timeout=1)
                
                readings = raw_packet.get("readings", [])
                processed_results = []
                
                for reading in readings:
                    # 调用边缘计算引擎
                    result = edge_engine.process(reading)
                    processed_results.append(result)
                    
                    # 检测到事件时打印
                    if result.get("event_type") != "none":
                        with state_mutex:
                            system_state["events_detected"] += 1
                        event_desc = result.get("description", "")
                        print(f"\n🎯 事件检测: [{result['event_type']}] {event_desc}")
                
                # 封装处理后的数据
                processed_packet = {
                    "type": "processed_batch",
                    "results": processed_results,
                    "active_sensors": raw_packet.get("active_sensors", []),
                    "cycle": raw_packet.get("cycle", 0),
                    "timestamp": datetime.now().isoformat()
                }
                
                # 推入处理后队列
                if not xProcessedDataQueue.full():
                    xProcessedDataQueue.put(processed_packet, block=False)
                
                with state_mutex:
                    system_state["total_processed"] += 1
                
                self.cycle_count += 1
                
            except queue.Empty:
                continue
            except Exception as e:
                print(f"\n⚠️ 边缘计算异常: {e}")


# ================================================================

# Task 3: 通信管理任务

# 将处理后的数据发送给 APP (VM3)

# ================================================================

class CommManagerTask(RTOSTask):
    def __init__(self):
        super().__init__("CommManager", priority=3, core=0)
        self.server_socket = None
        self.app_socket = None
    

    def run(self):
        # 创建TCP服务器，等待APP连接
        self.server_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.server_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        self.server_socket.bind(('0.0.0.0', APP_SERVE_PORT))
        self.server_socket.listen(1)
        print(f"\n📱 等待APP连接 (端口 {APP_SERVE_PORT})...")
        
        while self.running:
            try:
                self.app_socket, addr = self.server_socket.accept()
                print(f"\n✅ APP已连接: {addr}")
                with state_mutex:
                    system_state["app_connected"] = True
                    system_state["offline_mode"] = False
                
                # 同步离线缓存数据
                self._sync_offline_cache()
                
                self._send_loop()
                
            except Exception as e:
                print(f"\n⚠️ APP连接异常: {e}")
                with state_mutex:
                    system_state["app_connected"] = False
                    system_state["offline_mode"] = True
                time.sleep(1)
    
    def _send_loop(self):
        """持续发送处理后的数据给APP"""
        while self.running:
            try:
                processed = xProcessedDataQueue.get(timeout=1)
                
                # 编码为协议格式
                message = protocol.encode(processed)
                
                try:
                    self.app_socket.sendall((message + "\n").encode('utf-8'))
                    self.cycle_count += 1
                except (BrokenPipeError, ConnectionResetError):
                    print("\n⚠️ APP连接断开，切换到离线模式")
                    with state_mutex:
                        system_state["app_connected"] = False
                        system_state["offline_mode"] = True
                    # 缓存数据
                    offline_cache.store(processed)
                    break
                    
            except queue.Empty:
                # 发送心跳包
                try:
                    heartbeat = protocol.encode_heartbeat(system_state)
                    self.app_socket.sendall((heartbeat + "\n").encode('utf-8'))
                except:
                    break
    
    def _sync_offline_cache(self):
        """APP重新连接时同步缓存数据"""
        cached = offline_cache.get_all()
        if cached:
            print(f"\n📤 正在同步 {len(cached)} 条离线缓存数据...")
            for item in cached:
                try:
                    message = protocol.encode(item)
                    self.app_socket.sendall((message + "\n").encode('utf-8'))
                    time.sleep(0.05)
                except:
                    break
            offline_cache.clear()
            print("✅ 离线数据同步完成")


# ================================================================

# Task 4: 离线游戏逻辑任务

# 当APP未连接时，在本地运行简单游戏逻辑

# ================================================================

class OfflineGameTask(RTOSTask):
    def __init__(self):
        super().__init__("OfflineGame", priority=2, core=1)
        self.local_achievements = []
    

    def run(self):
        while self.running:
            with state_mutex:
                is_offline = system_state["offline_mode"]
            
            if is_offline:
                # 离线模式激活
                try:
                    processed = xProcessedDataQueue.get(timeout=2)
                    
                    # 本地勋章判定
                    for result in processed.get("results", []):
                        medal = self._check_local_achievement(result)
                        if medal:
                            self.local_achievements.append(medal)
                            print(f"\n🏅 [离线] 解锁勋章: {medal['name']} — {medal['description']}")
                    
                    # 离线模式下缓存数据
                    offline_cache.store(processed)
                    
                except queue.Empty:
                    pass
            else:
                time.sleep(1)
    
    def _check_local_achievement(self, result):
        """本地简单勋章判定（不需要AI的基础勋章）"""
        event = result.get("event_type", "none")
        sensor = result.get("sensor_type", 0)
        value = result.get("calibrated_value", 0)
        
        # 基础勋章判定
        if event == "freefall_detected" and "newton_apple" not in [m.get("id") for m in self.local_achievements]:
            return {
                "id": "newton_apple", "name": "🍎 牛顿的苹果",
                "description": "检测到自由落体！重力加速度≈9.8m/s²"
            }
