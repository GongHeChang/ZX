def command_loop(simulator):
    """命令输入循环"""
    print_help()
    while True:
        try:
            cmd = input("\n> ").strip().lower()
            if not cmd:
                continue
            

            parts = cmd.split()
            
            if parts[0] == 'q':
                print("👋 传感器模拟器关闭")
                sys.exit(0)
            elif parts[0] == 'h':
                print_help()
            elif parts[0] == 'p' and len(parts) > 1:
                sensor_id = int(parts[1])
                simulator.plug_sensor(sensor_id)
            elif parts[0] == 'u' and len(parts) > 1:
                sensor_id = int(parts[1])
                simulator.unplug_sensor(sensor_id)
            elif parts[0] == 'e' and len(parts) > 1:
                event = parts[1]
                duration = int(parts[2]) if len(parts) > 2 else 10
                simulator.trigger_event(event, duration)
            else:
                print("❓ 未知命令，输入 h 查看帮助")
                
        except (ValueError, IndexError):
            print("❓ 命令格式错误，输入 h 查看帮助")
        except KeyboardInterrupt:
            print("\n👋 传感器模拟器关闭")
            sys.exit(0)


def main():
    print("=" * 56)
    print("    🔬 VM1 - 传感器模拟器")
    print("    模拟物理传感器数据采集")
    print("=" * 56)
    

    sim = SensorSimulator()
    
    # 连接到ESP32
    sim.connect_to_esp32()
    
    # 启动数据发送线程
    send_thread = threading.Thread(target=sim.data_sending_loop, daemon=True)
    send_thread.start()
    
    # 主线程运行命令输入
    command_loop(sim)


if __name__ == "__main__":
    main()



