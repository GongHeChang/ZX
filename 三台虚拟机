# ================================================================

# ESP32 数据接收线程

# ================================================================

def esp32_receiver():
    """持续连接ESP32并接收数据"""
    while True:
        try:
            print(f"\n📡 正在连接ESP32 ({ESP32_IP}:{ESP32_PORT})...")
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(10)
            sock.connect((ESP32_IP, ESP32_PORT))
            

            with state_lock:
                app_state["esp32_connected"] = True
            print(f"✅ 已连接到ESP32")
            
            buffer = ""
            while True:
                try:
                    data = sock.recv(4096).decode('utf-8')
                    if not data:
                        break
                    
                    buffer += data
                    while "\n" in buffer:
                        line, buffer = buffer.split("\n", 1)
                        try:
                            frame = json.loads(line)
                            process_esp32_frame(frame)
                        except json.JSONDecodeError:
                            pass
                            
                except socket.timeout:
                    continue
                    
        except (ConnectionRefusedError, OSError) as e:
            with state_lock:
                app_state["esp32_connected"] = False
            print(f"⏳ 等待ESP32连接... ({e})")
            time.sleep(3)
        except Exception as e:
            with state_lock:
                app_state["esp32_connected"] = False
            print(f"❌ ESP32连接错误: {e}")
            time.sleep(3)


def process_esp32_frame(frame):
    """处理从ESP32收到的数据帧"""
    frame_type = frame.get("type")
    payload = frame.get("payload")
    

    if not payload:
        return
    
    if frame_type == 0x01:  # 传感器数据
        results = payload.get("results", [])
        
        with state_lock:
            app_state["sensor_data"] = results
            
            # 更新历史记录
            for r in results:
                stype = r.get("sensor_type", 0)
                if stype not in app_state["sensor_history"]:
                    app_state["sensor_history"][stype] = []
                app_state["sensor_history"][stype].append({
                    "value": r.get("calibrated_value", 0),
                    "computed": r.get("computed_value", 0),
                    "time": datetime.now().strftime("%H:%M:%S")
                })
                # 只保留最近100个数据点
                if len(app_state["sensor_history"][stype]) > 100:
                    app_state["sensor_history"][stype] = app_state["sensor_history"][stype][-100:]
                
                # 检测事件
                event_type = r.get("event_type", "none")
                if event_type != "none":
                    event_data = {
                        "type": event_type,
                        "description": r.get("description", ""),
                        "sensor": r.get("sensor_name", ""),
                        "value": r.get("calibrated_value", 0),
                        "time": datetime.now().strftime("%H:%M:%S")
                    }
                    app_state["events"].insert(0, event_data)
                    app_state["events"] = app_state["events"][:50]  # 保留最近50个
                    
                    # 自动触发AI对话
                    auto_ai_respond(event_data, r)
        
        # 放入实时队列
        if not latest_data_queue.full():
            latest_data_queue.put(results, block=False)
    
    elif frame_type == 0xFF:  # 心跳包
        with state_lock:
            app_state["system_status"] = payload


def auto_ai_respond(event_data, sensor_result):
    """事件触发时自动请求AI回复"""
    try:
        sensor_context = {
            "events": [event_data],
            "latest_reading": {
                "sensor_type": sensor_result.get("sensor_type"),
                "value": sensor_result.get("calibrated_value"),
                "unit": sensor_result.get("unit")
            }
        }
        

        response = ai_client.chat(
            f"传感器检测到事件: {event_data['description']}",
            sensor_context=sensor_context
        )
        
        if response.get("success"):
            with state_lock:
                # 添加AI回复到聊天历史
                app_state["chat_history"].append({
                    "role": "system",
                    "content": f"🎯 事件触发: {event_data['description']}",
                    "time": datetime.now().strftime("%H:%M:%S")
                })
                app_state["chat_history"].append({
                    "role": "assistant",
                    "content": response["reply"],
                    "time": datetime.now().strftime("%H:%M:%S")
                })
                
                # 检查勋章
                if response.get("medal"):
                    medal = response["medal"]
                    if medal["id"] not in [m["id"] for m in app_state["medals"]]:
                        app_state["medals"].append(medal)
                        app_state["chat_history"].append({
                            "role": "medal",
                            "content": f"🏅 解锁勋章: {medal['name']} ({medal['rarity']})",
                            "time": datetime.now().strftime("%H:%M:%S")
                        })
                
                # 记录知识点
                if response.get("knowledge"):
                    app_state["knowledge_points"].append({
                        "content": response["knowledge"],
                        "time": datetime.now().strftime("%H:%M:%S")
                    })
                
    except Exception as e:
        print(f"⚠️ AI自动回复异常: {e}")


# ================================================================

# Flask 路由

# ================================================================

@app.route('/')
def index():
    return render_template('index.html')

@app.route('/api/state')
def get_state():
    """获取当前完整状态"""
    with state_lock:
        return jsonify(app_state)

@app.route('/api/sensor_data')
def get_sensor_data():
    """获取最新传感器数据"""
    with state_lock:
        return jsonify({
            "data": app_state["sensor_data"],
            "history": app_state["sensor_history"]
        })

@app.route('/api/events')
def get_events():
    """获取事件列表"""
    with state_lock:
        return jsonify(app_state["events"])

@app.route('/api/chat', methods=['POST'])
def chat():
    """用户手动发送消息给AI"""
    user_message = request.json.get("message", "")
    

    if not user_message.strip():
        return jsonify({"success": False, "reply": "请输入消息"})
    
    # 记录用户消息
    with state_lock:
        app_state["chat_history"].append({
            "role": "user",
            "content": user_message,
            "time": datetime.now().strftime("%H:%M:%S")
        })
        current_sensors = app_state["sensor_data"]
    
    # 调用AI
    sensor_context = {
        "latest_readings": current_sensors,
        "active_sensors": [d.get("sensor_name") for d in current_sensors]
    }
    
    response = ai_client.chat(user_message, sensor_context=sensor_context)
    
    with state_lock:
        app_state["chat_history"].append({
            "role": "assistant",
            "content": response.get("reply", "..."),
            "time": datetime.now().strftime("%H:%M:%S")
        })
        
        if response.get("medal"):
            medal = response["medal"]
            if medal["id"] not in [m["id"] for m in app_state["medals"]]:
                app_state["medals"].append(medal)
        
        if response.get("knowledge"):
            app_state["knowledge_points"].append({
                "content": response["knowledge"],
                "time": datetime.now().strftime("%H:%M:%S")
            })
    
    return jsonify(response)

@app.route('/api/medals')
def get_medals():
    """获取已解锁勋章"""
    with state_lock:
        return jsonify(app_state["medals"])

@app.route('/api/chat_history')
def get_chat_history():
    """获取聊天历史"""
    with state_lock:
        return jsonify(app_state["chat_history"][-50:])

@app.route('/api/knowledge')
def get_knowledge():
    """获取已学知识点"""
    with state_lock:
        return jsonify(app_state["knowledge_points"])


# ================================================================

# 启动

# ================================================================

if __name__ == '__main__':
    print("=" * 60)
    print("    📱 VM3 - 上位机APP模拟器")
    print("    模拟移动端APP界面和AI交互")
    print("=" * 60)
    

    # 启动ESP32数据接收线程
    esp32_thread = threading.Thread(target=esp32_receiver, daemon=True)
    esp32_thread.start()
    
    print(f"\n🌐 Web界面: http://localhost:{WEB_PORT}")
    print(f"   也可在其他电脑用 http://VM3的IP:{WEB_PORT} 访问")
    
    app.run(host='0.0.0.0', port=WEB_PORT, debug=False)
















