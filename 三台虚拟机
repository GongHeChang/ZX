    "knowledge_points": [],      # 已学到的知识点
}
state_lock = threading.Lock()

# 最新数据队列（给前端实时推送用）

latest_data_queue = queue.Queue(maxsize=100)

# AI客户端

# 如果有COZE API Token就用真实客户端，否则用模拟客户端

if COZE_API_TOKEN != "pat_WthcSui7hzejyAz2xYcrbnqsRpwGeWm4gFbPUappyVmlK7TKJbPLIC11EGeQVnD0" and COZE_BOT_ID != "7627689802107994166":
