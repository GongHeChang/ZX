.event-item{padding:8px 12px;border-radius:8px;margin-bottom:6px;background:rgba(255,255,255,0.03);border-left:3px solid var(--orange);font-size:0.78rem}
.event-item .event-time{font-size:0.65rem;color:var(--text2)}
.event-item .event-sensor{color:var(--cyan);font-weight:600}
.event-item .event-desc{color:var(--text);margin-top:2px}

/* Medal Gallery */
.medal-list{display:flex;flex-wrap:wrap;gap:8px}
.medal-item{display:flex;align-items:center;gap:8px;padding:8px 12px;border-radius:10px;background:rgba(255,255,255,0.03);border:1px solid var(--border)}
.medal-item .medal-icon-big{font-size:1.5rem}
.medal-item .medal-info .medal-n{font-size:0.82rem;font-weight:700}
.medal-item .medal-info .medal-r{font-size:0.68rem;color:var(--orange)}

/* Knowledge Board */
.knowledge-item{padding:8px 12px;border-radius:8px;margin-bottom:6px;background:rgba(168,85,247,0.08);border:1px solid rgba(168,85,247,0.15);font-size:0.8rem;line-height:1.5}
.knowledge-item .k-time{font-size:0.65rem;color:var(--text2)}

/* Tabs in panel */
.panel-tabs{display:flex;border-bottom:1px solid var(--border);flex-shrink:0}
.panel-tab{flex:1;padding:8px;text-align:center;font-size:0.78rem;font-weight:600;color:var(--text2);cursor:pointer;border-bottom:2px solid transparent;transition:all 0.3s}
.panel-tab:hover{color:var(--text)}
.panel-tab.active{color:var(--blue);border-bottom-color:var(--blue)}
.tab-panel{display:none}
.tab-panel.active{display:block}

/* Scrollbar */
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.1);border-radius:2px}

/* Empty state */
.empty-state{text-align:center;padding:30px;color:var(--text2);font-size:0.85rem}
.empty-state .empty-icon{font-size:2rem;margin-bottom:8px}

@media(max-width:768px){
  .app-container{grid-template-columns:1fr;grid-template-rows:auto auto 1fr}
  .sensor-grid{grid-template-columns:repeat(4,1fr)}
}
</style>
</head>
<body>

<div class="app-container">
  <!-- Header -->
  <div class="header">
    <h1>🔬 探索精灵·小光 — 知识结晶世界</h1>
    <div class="status-badges">
      <span id="badge-esp32" class="badge badge-err">🔴 ESP32 未连接</span>
      <span id="badge-sensors" class="badge badge-info">🔌 传感器: 0</span>
      <span id="badge-medals" class="badge badge-info">🏅 勋章: 0</span>
      <span id="badge-knowledge" class="badge badge-info">📚 知识点: 0</span>
    </div>
  </div>


  <!-- Left: Sensor + Events -->

  <div class="panel">
    <div class="panel-tabs">
      <div class="panel-tab active" onclick="switchLeftTab('sensors')">📡 传感器</div>
      <div class="panel-tab" onclick="switchLeftTab('events')">🎯 事件</div>
      <div class="panel-tab" onclick="switchLeftTab('medals')">🏅 勋章</div>
      <div class="panel-tab" onclick="switchLeftTab('knowledge')">📚 知识</div>
    </div>
    <div class="panel-body">
      <!-- Sensors Tab -->
      <div id="tab-sensors" class="tab-panel active">
        <div class="sensor-grid" id="sensorGrid">
          <div class="empty-state">
            <div class="empty-icon">📡</div>
            等待传感器数据...
          </div>
        </div>
      </div>
      <!-- Events Tab -->
      <div id="tab-events" class="tab-panel">
        <div id="eventList">
          <div class="empty-state">
            <div class="empty-icon">🎯</div>
            还没有检测到事件<br>试试操作传感器！
          </div>
        </div>
      </div>
      <!-- Medals Tab -->
      <div id="tab-medals" class="tab-panel">
        <div class="medal-list" id="medalList">
          <div class="empty-state">
            <div class="empty-icon">🏅</div>
            还没有解锁勋章<br>触发传感器事件来收集！
          </div>
        </div>
      </div>
      <!-- Knowledge Tab -->
      <div id="tab-knowledge" class="tab-panel">
        <div id="knowledgeList">
          <div class="empty-state">
            <div class="empty-icon">📚</div>
            知识面板<br>探索越多，知识越丰富！
          </div>
        </div>
      </div>
    </div>
  </div>


  <!-- Right: Chat with AI -->

  <div class="panel" style="display:flex;flex-direction:column">
    <div class="panel-header">💬 与小光对话</div>
    <div class="panel-body" id="chatMessages" style="flex:1">
      <div class="chat-messages" id="chatContainer">
        <div class="chat-msg msg-assistant">
          <div>🌟 你好呀，小探索家！我是探索精灵·小光！<br><br>
          我住在知识结晶世界里。快连接传感器，和我一起探索物理世界的奇妙吧！<br><br>
          你可以：<br>
          • 在VM1终端输入 <b>p 4</b> 插入加速度传感器<br>
          • 输入 <b>e freefall</b> 模拟自由落体<br>
          • 或者直接和我聊天问问题！</div>
          <div class="msg-time">系统</div>
        </div>
      </div>
    </div>
    <div class="chat-input-row">
      <button class="voice-btn" id="voiceBtn" onclick="toggleVoice()" title="语音输入">🎤</button>
      <input class="chat-input" id="chatInput" placeholder="和小光说说话..." onkeydown="if(event.key==='Enter')sendMessage()">
      <button class="chat-send" onclick="sendMessage()">发送 ✨</button>
    </div>
  </div>

</div>

<script>
// ========== 常量 ==========
const SENSOR_ICONS = {1:'🌡️',2:'💡',3:'🔊',4:'🏃',5:'📏',6:'💧',7:'🌀',8:'🧲'};
const SENSOR_NAMES = {1:'温度',2:'光线',3:'声音',4:'加速度',5:'距离',6:'湿度',7:'气压',8:'磁场'};


// ========== 状态轮询 ==========
let pollInterval;

function startPolling() {
  pollInterval = setInterval(async () => {
    try {
      const resp = await fetch('/api/state');
      const state = await resp.json();
      updateUI(state);
    } catch(e) {
      console.error('轮询失败:', e);
    }
  }, 500);
}

function updateUI(state) {
  // 更新状态徽章
  const esp32Badge = document.getElementById('badge-esp32');
  if (state.esp32_connected) {
    esp32Badge.className = 'badge badge-ok';
    esp32Badge.textContent = '🟢 ESP32 已连接';
  } else {
    esp32Badge.className = 'badge badge-err';
    esp32Badge.textContent = '🔴 ESP32 未连接';
  }

  const activeSensors = (state.sensor_data || []).length;
  document.getElementById('badge-sensors').textContent = `🔌 传感器: ${activeSensors}`;
  document.getElementById('badge-medals').textContent = `🏅 勋章: ${(state.medals||[]).length}`;
  document.getElementById('badge-knowledge').textContent = `📚 知识: ${(state.knowledge_points||[]).length}`;

  // 更新传感器面板
  updateSensors(state.sensor_data || []);

  // 更新事件列表
  updateEvents(state.events || []);

  // 更新勋章
  updateMedals(state.medals || []);

  // 更新知识点
  updateKnowledge(state.knowledge_points || []);

  // 更新聊天（增量更新）
  updateChat(state.chat_history || []);
}

function updateSensors(data) {
  const grid = document.getElementById('sensorGrid');
  if (!data.length) {
    grid.innerHTML = '<div class="empty-state"><div class="empty-icon">📡</div>等待传感器数据...<br><small>在VM1中输入 p 1 插入温度传感器</small></div>';
    return;
  }

  grid.innerHTML = data.map(d => {
    const hasEvent = d.event_type && d.event_type !== 'none';
    const cls = hasEvent ? 'sensor-card active event' : 'sensor-card active';
    return `
      <div class="${cls}">
        <div class="sensor-icon">${SENSOR_ICONS[d.sensor_type] || '❓'}</div>
        <div class="sensor-name">${d.sensor_name || SENSOR_NAMES[d.sensor_type] || '未知'}</div>
        <div class="sensor-value">${typeof d.calibrated_value === 'number' ? d.calibrated_value.toFixed(2) : d.calibrated_value}<span class="sensor-unit">${d.unit || ''}</span></div>
        <div class="sensor-event">${hasEvent ? '⚡ ' + d.description : ''}</div>
      </div>
    `;
  }).join('');
}

function updateEvents(events) {
  const list = document.getElementById('eventList');
  if (!events.length) {
    list.innerHTML = '<div class="empty-state"><div class="empty-icon">🎯</div>还没有检测到事件</div>';
    return;
  }
  list.innerHTML = events.slice(0, 20).map(e => `
    <div class="event-item">
      <span class="event-time">${e.time}</span> 
      <span class="event-sensor">${e.sensor}</span>
      <div class="event-desc">${e.description}</div>
    </div>
  `).join('');
}

function updateMedals(medals) {
  const list = document.getElementById('medalList');
  if (!medals.length) {
    list.innerHTML = '<div class="empty-state"><div class="empty-icon">🏅</div>还没有解锁勋章</div>';
    return;
  }
  list.innerHTML = medals.map(m => `
    <div class="medal-item">
      <span class="medal-icon-big">${m.name.split(' ')[0]}</span>
      <div class="medal-info">
        <div class="medal-n">${m.name}</div>
        <div class="medal-r">${m.rarity}</div>
      </div>
    </div>
  `).join('');
}

function updateKnowledge(points) {
  const list = document.getElementById('knowledgeList');
  if (!points.length) {
    list.innerHTML = '<div class="empty-state"><div class="empty-icon">📚</div>知识面板</div>';
    return;
  }
  list.innerHTML = points.map(k => `
    <div class="knowledge-item">
      <div class="k-time">${k.time}</div>
      <div>📖 ${k.content}</div>
    </div>
  `).join('');
}

let lastChatLength = 1; // 初始有一条欢迎消息
function updateChat(history) {
  if (history.length <= lastChatLength - 1) return; // 没有新消息（减1是因为初始欢迎消息）

  const container = document.getElementById('chatContainer');

  // 只添加新消息
  const newMsgs = history.slice(Math.max(0, lastChatLength - 1));
  for (const msg of newMsgs) {
    const div = document.createElement('div');
    let cls = 'msg-assistant';
    if (msg.role === 'user') cls = 'msg-user';
    else if (msg.role === 'system') cls = 'msg-system';
    else if (msg.role === 'medal') cls = 'msg-medal';
    

    div.className = `chat-msg ${cls}`;
    div.innerHTML = `<div>${msg.content.replace(/\n/g, '<br>')}</div><div class="msg-time">${msg.time}</div>`;
    container.appendChild(div);

  }

  lastChatLength = history.length + 1;

  // 滚动到底部
  const panel = document.getElementById('chatMessages');
  panel.scrollTop = panel.scrollHeight;

  // 语音朗读最新AI回复
  if (newMsgs.length > 0) {
    const lastMsg = newMsgs[newMsgs.length - 1];
    if (lastMsg.role === 'assistant' && window.speechSynthesis) {
      speakText(lastMsg.content);
    }
  }
}

// ========== 聊天发送 ==========
async function sendMessage() {
  const input = document.getElementById('chatInput');
  const msg = input.value.trim();
  if (!msg) return;

  input.value = '';

  // 立即显示用户消息
  const container = document.getElementById('chatContainer');
  const div = document.createElement('div');
  div.className = 'chat-msg msg-user';
  div.innerHTML = `<div>${msg}</div><div class="msg-time">发送中...</div>`;
  container.appendChild(div);
  document.getElementById('chatMessages').scrollTop = container.scrollHeight;

  try {
    const resp = await fetch('/api/chat', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({message: msg})
    });
    const data = await resp.json();
    // 回复会通过状态轮询自动显示
  } catch(e) {
    console.error('发送失败:', e);
  }
}

// ========== 语音功能 ==========
let isRecording = false;
let recognition = null;

function toggleVoice() {
  if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) {
    addSystemMsg('⚠️ 你的浏览器不支持语音输入，请使用Chrome浏览器');
    return;
  }

  if (isRecording) {
    stopVoice();
  } else {
    startVoice();
  }
}

function startVoice() {
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  recognition = new SpeechRecognition();
  recognition.lang = 'zh-CN';
  recognition.continuous = false;
  recognition.interimResults = false;

  recognition.onresult = (event) => {
    const text = event.results[0][0].transcript;
    document.getElementById('chatInput').value = text;
    sendMessage();
  };

  recognition.onerror = (event) => {
    console.error('语音识别错误:', event.error);
    stopVoice();
  };

  recognition.onend = () => {
    stopVoice();
  };

  recognition.start();
  isRecording = true;
  document.getElementById('voiceBtn').classList.add('recording');
}

function stopVoice() {
  if (recognition) {
    recognition.stop();
  }
  isRecording = false;
  document.getElementById('voiceBtn').classList.remove('recording');
}

function speakText(text) {
  // 清理文本（去除emoji和特殊字符）
  const cleanText = text.replace(/[\u{1F300}-\u{1F9FF}]/gu, '').replace(/\n/g, '。').substring(0, 200);

  if ('speechSynthesis' in window && cleanText.trim()) {
    window.speechSynthesis.cancel();
    const utterance = new SpeechSynthesisUtterance(cleanText);
    utterance.lang = 'zh-CN';
    utterance.rate = 0.9;
    utterance.pitch = 1.2; // 稍高的音调，更适合给儿童
    window.speechSynthesis.speak(utterance);
  }
}

function addSystemMsg(text) {
  const container = document.getElementById('chatContainer');
  const div = document.createElement('div');
  div.className = 'chat-msg msg-system';
  div.innerHTML = `<div>${text}</div>`;
  container.appendChild(div);
}




// ========== 左侧面板Tab ==========
function switchLeftTab(tabName) {
  document.querySelectorAll('.panel-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(t => t.classList.remove('active'));
  event.target.classList.add('active');
  document.getElementById('tab-' + tabName).classList.add('active');
}

// ========== 启动 ==========
startPolling();
</script>
</body>
</html>
