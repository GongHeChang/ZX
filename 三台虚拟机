#!/usr/bin/env python3

"""
====================================================

VM1 - 传感器模拟器
====================================================

模拟8种传感器的数据采集，通过TCP发送给ESP32（VM2）

每种传感器按真实物理范围生成随机数据，并可手动触发特殊事件
====================================================

"""

import socket
import json
import time
import math
import random
import threading
import sys
from datetime import datetime

# ========== 配置 ==========

ESP32_IP = "192.168.110.129"  # ← 替换为VM2的实际IP
ESP32_PORT = 9001
SEND_INTERVAL = 0.5  # 每0.5秒发送一次数据

# ========== 传感器类型定义 ==========

SENSOR_TYPES = {
    1: {"name": "温度传感器",    "unit": "°C",   "min": -10, "max": 50,    "icon": "🌡️"},
    2: {"name": "光线传感器",    "unit": "Lux",  "min": 0,   "max": 65535, "icon": "💡"},
    3: {"name": "声音传感器",    "unit": "mV",   "min": 0,   "max": 1024,  "icon": "🔊"},
    4: {"name": "加速度传感器",  "unit": "m/s²", "min": -20, "max": 20,    "icon": "🏃"},
    5: {"name": "距离传感器",    "unit": "cm",   "min": 2,   "max": 400,   "icon": "📏"},
    6: {"name": "湿度传感器",    "unit": "%RH",  "min": 0,   "max": 100,   "icon": "💧"},
    7: {"name": "气压传感器",    "unit": "hPa",  "min": 300, "max": 1100,  "icon": "🌀"},
    8: {"name": "磁场传感器",    "unit": "μT",   "min": -100,"max": 100,   "icon": "🧲"},
}

class SensorSimulator:
    """传感器模拟器主类"""
    

    def __init__(self):
        # 当前激活的传感器（模拟"插入"效果）
        self.active_sensors = {1: True}  # 默认只有温度传感器
        
        # 各传感器的当前基准值（模拟真实环境）
        self.base_values = {
            1: 25.0,    # 室温25°C
            2: 500.0,   # 室内光照500Lux
            3: 100.0,   # 环境噪音
            4: 9.8,     # 静止时重力加速度
            5: 100.0,   # 100cm距离
            6: 45.0,    # 45%湿度
            7: 1013.25, # 标准大气压
            8: 30.0,    # 地磁场约30μT
        }
        
        # 特殊事件标记
        self.special_event = None
        self.event_duration = 0
        
        # 连接状态
        self.connected = False
        self.socket = None
        
    def generate_sensor_data(self, sensor_id):
        """生成带有自然波动的传感器数据"""
        info = SENSOR_TYPES[sensor_id]
        base = self.base_values[sensor_id]
        
        # 添加自然噪声（正弦波动 + 随机噪声）
        time_factor = time.time()
        natural_wave = math.sin(time_factor * 0.5) * (info["max"] - info["min"]) * 0.01
        noise = random.gauss(0, (info["max"] - info["min"]) * 0.005)
        
        value = base + natural_wave + noise
        
        # 处理特殊事件
        if self.special_event and self.event_duration > 0:
            value = self._apply_special_event(sensor_id, value)
            self.event_duration -= 1
            if self.event_duration <= 0:
                self.special_event = None
        
        # 确保在合理范围内
        value = max(info["min"], min(info["max"], value))
        
        return {
            "sensor_id": sensor_id,
            "sensor_type": sensor_id,
            "sensor_name": info["name"],
            "raw_value": round(value, 3),
            "unit": info["unit"],
            "timestamp": datetime.now().isoformat(),
            "quality": random.randint(85, 100)
        }
    
    def _apply_special_event(self, sensor_id, value):
        """应用特殊事件到传感器数据"""
        if self.special_event == "freefall" and sensor_id == 4:
            return random.uniform(0.1, 0.5)  # 近似失重
        elif self.special_event == "hot_touch" and sensor_id == 1:
            return self.base_values[1] + random.uniform(5, 12)  # 手握升温
        elif self.special_event == "cold_touch" and sensor_id == 1:
            return random.uniform(-5, 5)  # 冰块降温
        elif self.special_event == "loud_sound" and sensor_id == 3:
            return random.uniform(800, 1020)  # 大声
        elif self.special_event == "bright_light" and sensor_id == 2:
            return random.uniform(10000, 50000)  # 强光
        elif self.special_event == "dark" and sensor_id == 2:
            return random.uniform(0, 10)  # 遮挡
        elif self.special_event == "shake" and sensor_id == 4:
            return random.uniform(-15, 15)  # 摇晃
        elif self.special_event == "magnet" and sensor_id == 8:
            return random.uniform(60, 100)  # 靠近磁铁
        return value
    
    def trigger_event(self, event_name, duration=10):
        """触发特殊事件"""
        self.special_event = event_name
        self.event_duration = duration  # 持续几个采集周期
        print(f"\n🎯 特殊事件触发: {event_name} (持续{duration}个周期)")
    
    def plug_sensor(self, sensor_id):
        """模拟插入传感器"""
        if sensor_id in SENSOR_TYPES:
            self.active_sensors[sensor_id] = True
            info = SENSOR_TYPES[sensor_id]
            print(f"\n🔌 传感器已插入: {info['icon']} {info['name']} (ID:{sensor_id})")
    
    def unplug_sensor(self, sensor_id):
        """模拟拔出传感器"""
        if sensor_id in self.active_sensors:
            del self.active_sensors[sensor_id]
            info = SENSOR_TYPES[sensor_id]
            print(f"\n⏏️  传感器已拔出: {info['icon']} {info['name']} (ID:{sensor_id})")
    
    def connect_to_esp32(self):
        """连接到ESP32模拟器"""
        while True:
            try:
                self.socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                self.socket.connect((ESP32_IP, ESP32_PORT))
                self.connected = True
                print(f"\n✅ 已连接到ESP32模拟器 ({ESP32_IP}:{ESP32_PORT})")
                return True
            except ConnectionRefusedError:
                print(f"⏳ 等待ESP32模拟器启动... ({ESP32_IP}:{ESP32_PORT})")
                time.sleep(3)
            except Exception as e:
                print(f"❌ 连接失败: {e}")
                time.sleep(3)
    
    def send_data(self, data):
        """发送数据到ESP32"""
        try:
            message = json.dumps(data) + "\n"
            self.socket.sendall(message.encode('utf-8'))
            return True
        except (BrokenPipeError, ConnectionResetError, OSError):
            self.connected = False
            print("\n❌ 与ESP32的连接断开，尝试重连...")
            self.connect_to_esp32()
            return False
    
    def data_sending_loop(self):
        """数据发送主循环"""
        cycle = 0
        while True:
            if not self.connected:
                time.sleep(1)
                continue
                
            # 收集所有激活传感器的数据
            sensor_readings = []
            for sensor_id in list(self.active_sensors.keys()):
                data = self.generate_sensor_data(sensor_id)
                sensor_readings.append(data)
            
            # 打包发送
            packet = {
                "type": "sensor_batch",
                "active_sensors": list(self.active_sensors.keys()),
                "readings": sensor_readings,
                "cycle": cycle
            }
            
            if self.send_data(packet):
                # 简洁的状态显示
                active_icons = " ".join(
                    [SENSOR_TYPES[sid]["icon"] for sid in self.active_sensors]
                )
                values_str = " | ".join(
                    [f"{d['raw_value']}{d['unit']}" for d in sensor_readings]
                )
                sys.stdout.write(
                    f"\r📡 周期#{cycle:04d} [{active_icons}] {values_str}    "
                )
                sys.stdout.flush()
            
            cycle += 1
            time.sleep(SEND_INTERVAL)


