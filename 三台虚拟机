        """

离线缓存系统
在APP断连时缓存数据，重连后自动同步
"""
import threading
import json
from collections import deque

class OfflineCache:
    def __init__(self, max_size=500):
        self.max_size = max_size
        self.cache = deque(maxlen=max_size)
        self.lock = threading.Lock()
    

    def store(self, data):
        with self.lock:
            self.cache.append(data)
    
    def get_all(self):
        with self.lock:
            items = list(self.cache)
            return items
    
    def clear(self):
        with self.lock:
            self.cache.clear()
    
    def count(self):
        with self.lock:
            return len(self.cache)














